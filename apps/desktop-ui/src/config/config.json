{
  "theme": "system",
  "hotkeys": {
    "global": {
      "undo": { "code": "KeyZ", "label": "Z", "ctrlOrMeta": true },
      "redo": { "code": "KeyZ", "label": "Z", "ctrlOrMeta": true, "shift": true }
    },
    "toolbar": {
      "extrude": { "code": "KeyE", "label": "E" },
      "fillet": { "code": "KeyF", "label": "F" },
      "project": { "code": "KeyP", "label": "P" }
    },
    "sketchToolbar": {
      "line": { "code": "KeyL", "label": "L" },
      "rectangle": { "code": "KeyR", "label": "R" },
      "circle": { "code": "KeyC", "label": "C" },
      "dimension": { "code": "KeyD", "label": "D" },
      "toggleConstruction": { "code": "KeyX", "label": "X" }
    }
  }
}
